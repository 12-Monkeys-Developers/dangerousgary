<section class="tab standard-form character-inventory {{tab.cssClass}}" data-group="primary" data-tab="inventory">
  <div class="equipment-points">
    <span class="equipment-points-label">{{localize "DANGEROUSGARY.Labels.long.equipmentPoints"}}</span>
    {{formInput systemFields.equipmentPoints value=system.equipmentPoints }}
  </div>
  <div class="character-items-list">
    {{#each items as |item|}}
      <div class="item {{#if item.system.hasDamage}}draggable{{/if}}" data-item-id="{{item.id}}" data-drag-type="rollDamage">
        <details>
          <summary>
            <span>
              <span class="item-name" data-tooltip="{{{item.enrichedDescription}}}">
                {{item.name}}
              </span>
              {{#if item.system.isBulky}}
                <span class="item-info">{{localize "DANGEROUSGARY.Equipment.FIELDS.bulky.label"}}</span>
              {{/if}}
              {{#if item.system.isArmor}}
                <span class="item-info">{{localize "DANGEROUSGARY.Labels.long.armour"}} {{item.system.armour}}</span>
              {{/if}}
              {{#if item.system.hasDamage}}
                <span class="item-info">{{item.system.damageFormula}} {{localize "DANGEROUSGARY.Labels.long.damage"}}</span>
              {{/if}}
              {{#if item.system.criticalDamage}}
                <span class="item-info critical-damage" data-tooltip="{{localize 'DANGEROUSGARY.Equipment.FIELDS.criticalDamage.label'}}"><i class="fas fa-burst"></i></span>
              {{/if}}
            </span>
          </summary>
          <div class="item-description">{{{item.enrichedDescription}}}</div>
        </details>
        <div class="item-controls">
          {{#if item.system.isEquipped}}
            {{#if item.system.hasDamage}}
              <span class="rollable" data-action="rollDamage" data-name="{{item.name}}" data-formula="{{item.system.damageFormula}}" data-critical-damage="{{item.system.criticalDamage}}" data-tooltip="{{localize 'DANGEROUSGARY.RollDamageTooltip'}}" data-tooltip-direction="UP">
                <i class="fas fa-dice-d20"></i>
              </span>
            {{/if}}
            <a data-tooltip="{{localize 'DANGEROUSGARY.Unequip'}}" data-action="unequip" data-item-id="{{item.id}}"><i class="fa-solid fa-shield"></i></a>
          {{/if}}
          {{#if (not item.system.isEquipped)}}
            <a data-tooltip="{{localize 'DANGEROUSGARY.Equip'}}" data-action="equip" data-item-id="{{item.id}}"><i class="fa-regular fa-shield"></i></a>
          {{/if}}
          <a data-tooltip="{{localize 'DANGEROUSGARY.Edit'}}" data-action="edit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
          <a data-tooltip="{{localize 'DANGEROUSGARY.Delete'}}" data-action="delete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
        </div>
      </div>
    {{/each}}
  </div>
  {{#if artefacts.length}}
  <div class="character-artefacts-list">
    {{#each artefacts as |item|}}
      <div class="artefact-item {{#unless item.artefactData.canUse}}artefact-unusable{{/unless}}" data-item-id="{{item.id}}">
        <details>
          <summary>
            <span>
              <i class="fas fa-gem artefact-icon"></i>
              <span class="item-name" data-tooltip="{{{item.enrichedDescription}}}">{{item.name}}</span>
              <span class="artefact-classes">
                {{#each item.artefactData.allowedClassLabels as |cls|}}
                  <span class="artefact-class-badge">{{cls}}</span>
                {{/each}}
              </span>
            </span>
          </summary>
          <div class="artefact-capacities">
            {{#each item.artefactData.capacities as |cap|}}
              <div class="artefact-capacity {{#if cap.unlocked}}unlocked{{else}}locked{{/if}}">
                <span class="capacity-level">{{localize "DANGEROUSGARY.Artefact.LevelAbbr"}} {{cap.level}}</span>
                <span class="capacity-description">{{{cap.description}}}</span>
                {{#if cap.unlocked}}
                  <a class="use-artefact" data-action="useArtefact"
                     data-item-id="{{../item.id}}" data-capacity-key="{{cap.key}}"
                     data-tooltip="{{localize 'DANGEROUSGARY.Artefact.UseCapacity'}}">
                    <i class="fas fa-hand-sparkles"></i>
                  </a>
                {{else}}
                  <i class="fas fa-lock capacity-lock"></i>
                {{/if}}
              </div>
            {{/each}}
          </div>
        </details>
        <div class="item-controls">
          <a data-tooltip="{{localize 'DANGEROUSGARY.Edit'}}" data-action="edit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
          <a data-tooltip="{{localize 'DANGEROUSGARY.Delete'}}" data-action="delete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
        </div>
      </div>
    {{/each}}
  </div>
  {{/if}}
  <div class="misc-equipment">
    {{formInput
      systemFields.equipmentMisc
      enriched=enrichedMiscEquipment
      value=system.equipmentMisc
      documentUUID=actor.uuid
      name="system.equipmentMisc"
      collaborate="true"
      toggled="true"
    }}
  </div>
</section>